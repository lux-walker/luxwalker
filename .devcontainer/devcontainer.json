{
  "name": "gleam",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "developer",
  "customizations": {
    "vscode": {
      "extensions": [
        "Gleam.gleam",
        "streetsidesoftware.code-spell-checker",
        "esbenp.prettier-vscode",
        "tamasfe.even-better-toml",
        "mikestead.dotenv",
        "humao.rest-client"
      ],
      "settings": {
        "gleam.path": "/usr/local/bin/gleam"
      }
    }
  },
  "forwardPorts": [8000],
  "postCreateCommand": "sudo chown -R developer:developer /home/developer/.config && mkdir -p /home/developer/.config/git && gleam --version && claude --version && gh --version",
  "mounts": [
    "source=luxwalker-user-config,target=/home/developer/.config,type=volume"
  ],
  "containerEnv": {
    "GIT_CONFIG_GLOBAL": "/home/developer/.config/git/config"
  },
  "remoteEnv": {}
}
